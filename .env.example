# unison-mastra environment variables
# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

# Required: your Unison API key (usk_live_...)
# Obtain one: curl -X POST https://brain.unisonlabs.ai/v1/auth/provision -d '{"email":"you@example.com"}'
UNISON_TOKEN=

# Optional: override the Unison API base URL (default: https://brain.unisonlabs.ai)
UNISON_API_URL=
